generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agents      Agent[]
  tasks       Task[]
  logs        ActivityLog[]
  runs        Run[]
  snapshots   Snapshot[]
  chatThreads ChatThread[]
  imports     ProjectImport[]
  modelConfigs ModelConfig[]
  memorySummaries MemorySummary[]
}

model Agent {
  id            String       @id @default(uuid())
  projectId String
  name          String
  role          String
  soulPath      String?
  toolsPath     String?
  status        String       @default("idle")
  memorySummary String?
  gatewayAgentId String?     // OpenClaw agent ID for this agent
  isOfficial    Boolean      @default(false)  // Whether this is an official KanClaw agent
  officialId    String?      // Reference to official agent template ID
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTasks Task[]       @relation("AgentTasks")
  chatThreads   ChatThread[]
  runs          Run[]
  modelConfigs  ModelConfig[]
}

model Task {
  id              String   @id @default(uuid())
  projectId       String
  title           String
  description     String?
  status          String
  assigneeAgentId String?
  parentTaskId    String?
  sourceRunId     String?
  originThreadId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, status])
  @@index([assigneeAgentId])
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeAgent   Agent?   @relation("AgentTasks", fields: [assigneeAgentId], references: [id], onDelete: SetNull)
  sourceRun       Run?     @relation("RunTasks", fields: [sourceRunId], references: [id], onDelete: SetNull)
  originThread    ChatThread? @relation(fields: [originThreadId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id        String   @id @default(uuid())
  projectId String
  timestamp DateTime @default(now())
  actor     String
  action    String
  details   String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp(sort: Desc)])
}

model Run {
  id        String   @id @default(uuid())
  projectId String
  taskId    String?
  agentId   String?
  threadId  String?
  origin    String
  title     String
  status    String
  input     String?
  output    String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, createdAt(sort: Desc)])
  @@index([agentId, status])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  thread    ChatThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  generatedTasks Task[] @relation("RunTasks")
}

model Snapshot {
  id        String   @id @default(uuid())
  projectId String
  title     String
  summary   String
  payload   String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id        String   @id @default(uuid())
  projectId String
  agentId   String?
  title     String
  scope     String
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]
  runs      Run[]
  tasks     Task[]
}

model ChatMessage {
  id              String   @id @default(uuid())
  threadId        String
  role            String
  actor           String
  targetAgentName String?
  content         String
  metadata        String?
  createdAt       DateTime @default(now())
  thread          ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ProjectImport {
  id            String   @id @default(uuid())
  projectId     String
  provider      String
  kind          String
  label         String
  owner         String?
  name          String
  externalId    String?
  sourceUrl     String?
  defaultBranch String?
  status        String
  summary       String?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider]) // Only one GitHub import per project
}
// KanClaw Control Plane - Model Configuration
model ModelConfig {
  id        String   @id @default(uuid())
  projectId String
  agentId   String?  // null for project default, specific for agent override
  provider  String
  model     String
  temperature Float?
  maxTokens Int?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, agentId])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// KanClaw Control Plane - Memory Summary
model MemorySummary {
  id          String   @id @default(uuid())
  projectId   String
  agentId     String?  // null for project-level, specific for agent
  summary     String
  context     String?  // JSON context for the summary
  sourceType  String   // 'handoff', 'periodic', 'manual'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, agentId])
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
